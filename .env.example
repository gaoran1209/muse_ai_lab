# =============================================================================
# Gemini LLM 模型配置
# 可用模型列表:
#   - gemini-2.5-flash          # 快速响应，免费额度较高，不支持 thinking
#   - gemini-2.5-flash-lite     # 更快速的简化版
#   - gemini-2.5-pro            # 专业版（需要付费）
#   - gemini-2.0-flash          # 第二代快速版
#   - gemini-flash-latest       # 最新 flash 版本
#   - gemini-3-flash-preview    # 第三代 flash 预览版，支持 thinking
#   - gemini-3-pro-preview      # 第三代专业版预览，支持 thinking（需要付费）
#   - gemini-3.1-pro-preview    # 第三代增强专业版预览，支持 thinking（需要付费）
#   - gemini-3.1-flash-preview  # 第三代增强 flash 预览版
#
# 注意:
#   - 支持 thinking_level 的模型: gemini-3-flash-preview, gemini-3-pro-preview,
#     gemini-3.1-pro-preview 等 gemini-3 系列
#   - 免费套餐推荐: gemini-2.5-flash, gemini-flash-latest
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# =============================================================================
# 智谱 GLM 模型配置
# 可用模型列表:
#   - glm-4.7-flash          # 快速响应版（推荐）
#   - glm-4.7-flashx         # 更快速的增强版
#   - glm-4.7                # 标准版
#   - glm-4.7-air            # 轻量版
#   - glm-4-plus             # 增强版
#   - glm-4-0520             # 稳定版本
#   - glm-4-flash            # Flash 版本
#   - glm-4-airx             # 轻量增强版
#   - glm-z1-plus            # Z1 增强版
#   - glm-z1-air             # Z1 轻量版
#   - glm-z1-preview         # Z1 预览版
#
# 注意:
#   - thinking_enabled 参数支持: glm-4.7, glm-4-plus 等专业版
#   - 免费套餐推荐: glm-4.7-flash
# =============================================================================
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL_NAME=glm-4.7-flash

# =============================================================================
# 302.AI 是一个 AI 模型聚合平台，提供 OpenAI 兼容格式的统一 API
# 官方文档: https://302ai.apifox.cn/api-147522041
# 价格: https://302.ai/price
# 注册: https://302.ai
# =============================================================================
# 302.AI API 密钥（用于 LLM、图片生成、视频生成）
THIRTYTWO_API_KEY=your_thirtytwo_api_key_here

# 302.AI LLM 模型配置
# 常用 Gemini 模型:
#   - gemini-2.5-flash                    # 快速响应版（推荐）
#   - gemini-2.5-pro                      # 专业版
#   - gemini-3-pro-preview                # 第三代专业版预览
#   - gemini-2.5-flash-preview-05-20      # Flash 预览版
#   - gemini-2.5-flash-lite-preview-06-17 # Flash 轻量版
#   - gemini-2.5-pro-preview-06-05        # Pro 预览版
#   - gemini-2.5-pro-preview-06-05-thinking # Pro 预览版（展示思考）
# 更多模型请参考: https://doc.302.ai/147522041e0
THIRTYTWO_LLM_MODEL=gemini-2.5-flash

# 302.AI 图片生成模型配置（Nano-Banana 自定义 API）
# Google Nano-Banana 系列:
#   - google/nano-banana-2           # Nano-Banana-2（性价比高）
#   - google/nano-banana-pro         # Nano-Banana-Pro（更高质量）
#   - google/nano-banana             # Nano-Banana（轻量版）
# Doubao Seedream 系列:
#   - doubao-seedream-5-0-260128     # Seedream 5.0（最新版本）
#   - doubao-seedream-4-5-251024     # Seedream 4.5
#   - doubao-seedream-4-0-250828     # Seedream 4.0
# 更多模型请参考: https://doc.302.ai/420136727e0
THIRTYTWO_IMAGE_MODEL=google/nano-banana-2

# 302.AI Gemini 图片生成（OpenAI 兼容 Chat Completions API）
# 通过 /v1/chat/completions 端点调用 Gemini 图片模型
# 可用模型:
#   - gemini-3.1-flash-image-preview   # Nano Banana 2（性价比高）
#   - gemini-3-pro-image-preview       # Nano Banana Pro（更高质量）
#   - gemini-3.1-flash-lite-preview    # 多模态 LLM
# API 文档: https://302ai.apifox.cn/343209599e0

# 302.AI 视频生成模型配置
# 可用模型:
#   - kling-v-1-5-260121    # Kling v1.5（默认，最新版本）
#   - kling-v-1-260121      # Kling v1
#   - kling-v2-5-turbo      # Kling v2.5 Turbo（快速版，仅文生视频）
# 文档: https://doc.302.ai/421815034e0
THIRTYTWO_VIDEO_MODEL=kling-v2-5-turbo

# =============================================================================
# 阿里云 OSS 配置
# 用于文件上传和图片存储
# =============================================================================
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=your_bucket_name_here
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_SECRET_ACCESS_KEY=your_secret_access_key_here
OSS_DISPLAY_HOST=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
OSS_REMOTE_DIR=upload

# =============================================================================
# 其他配置
# =============================================================================
DEBUG_MODE=false
DEMO_STORE_PATH=data/demo_store.json
